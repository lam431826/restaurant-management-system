{
  "info": {
    "name": "RMS API - Restaurant Management System",
    "_postman_id": "rms-api-collection-v2",
    "description": "Complete API collection for Restaurant Management System. Start by running 'Login (Admin)' — the token is auto-saved and used by all subsequent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",  "value": "http://localhost:8080", "type": "string" },
    { "key": "token",    "value": "", "type": "string" },
    { "key": "refresh",  "value": "", "type": "string" },
    { "key": "shiftId",  "value": "", "type": "string" },
    { "key": "userId",   "value": "", "type": "string" },
    { "key": "tableId",  "value": "", "type": "string" },
    { "key": "orderId",  "value": "", "type": "string" },
    { "key": "invoiceId","value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "01. Authentication",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.accessToken)  { pm.collectionVariables.set('token',   res.accessToken); }",
                  "if (res.refreshToken) { pm.collectionVariables.set('refresh', res.refreshToken); }",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has access token', () => pm.expect(res.accessToken).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.accessToken)  { pm.collectionVariables.set('token',   res.accessToken); }",
                  "if (res.refreshToken) { pm.collectionVariables.set('refresh', res.refreshToken); }",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","auth","refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","auth","logout"] }
          }
        }
      ]
    },

