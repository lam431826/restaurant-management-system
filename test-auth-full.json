    {
      "name": "2. Refresh Token & Logout",
      "item": [
        {
          "name": "2.1 Refresh token hợp lệ → JWT mới",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('accessToken mới', () => pm.expect(j.accessToken).to.be.a('string'));",
            "pm.test('refreshToken mới', () => pm.expect(j.refreshToken).to.be.a('string'));",
            "pm.collectionVariables.set('accessToken', j.accessToken);",
            "pm.collectionVariables.set('refreshToken', j.refreshToken);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "2.2 Refresh token không hợp lệ (random string) → 401",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"invalid.token.string\"\n}" }
          }
        },
        {
          "name": "2.3 Logout → 204 (lưu refreshToken đã dùng)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('204 No Content', () => pm.response.to.have.status(204));",
            "pm.collectionVariables.set('revokedRefreshToken', pm.collectionVariables.get('refreshToken'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/auth/logout",
            "body": { "mode": "raw", "raw": "" }
          }
        },
        {
          "name": "2.4 Refresh token đã revoke (sau logout) → 401",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{revokedRefreshToken}}\"\n}" }
          }
        },
        {
          "name": "2.5 Gọi endpoint bảo vệ sau logout → 401",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/auth/logout",
            "body": { "mode": "raw", "raw": "" }
          }
        }
      ]
    },

