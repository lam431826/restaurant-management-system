  },
  "variable": [
    { "key": "baseUrl",              "value": "http://localhost:8386" },
    { "key": "accessToken",          "value": "" },
    { "key": "refreshToken",         "value": "" },
    { "key": "revokedRefreshToken",  "value": "" },
    { "key": "verifyToken",          "value": "" },
    { "key": "otp",                  "value": "" }
