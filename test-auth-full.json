  "item": [

    {
      "name": "1. Login",
      "item": [
        {
          "name": "1.1 Login thành công → JWT (admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('accessToken', () => pm.expect(j.accessToken).to.be.a('string'));",
            "pm.test('refreshToken', () => pm.expect(j.refreshToken).to.be.a('string'));",
            "pm.test('user.role = ADMIN', () => pm.expect(j.user.role).to.eql('ADMIN'));",
            "pm.test('no requiresVerification', () => pm.expect(j.requiresVerification).to.be.undefined);",
            "pm.collectionVariables.set('accessToken', j.accessToken);",
            "pm.collectionVariables.set('refreshToken', j.refreshToken);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123456\"\n}" }
          }
        },
        {
          "name": "1.2 Login sai mật khẩu → 401 INVALID_CREDENTIALS",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "pm.test('401', () => pm.response.to.have.status(401));",
            "pm.test('error = INVALID_CREDENTIALS', () => pm.expect(j.error).to.eql('INVALID_CREDENTIALS'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"SaiMatKhau@999\"\n}" }
          }
        },
        {
          "name": "1.3 Login username không tồn tại → 401 INVALID_CREDENTIALS",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "pm.test('401', () => pm.response.to.have.status(401));",
            "pm.test('error = INVALID_CREDENTIALS', () => pm.expect(j.error).to.eql('INVALID_CREDENTIALS'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"khong_ton_tai\",\n  \"password\": \"Abc@123\"\n}" }
          }
        },
        {
          "name": "1.4 Login UN_ACTIVE → requiresVerification (TanTDHE191221)",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('requiresVerification = true', () => pm.expect(j.requiresVerification).to.be.true);",
            "pm.test('verifyToken present', () => pm.expect(j.verifyToken).to.be.a('string'));",
            "pm.test('no accessToken', () => pm.expect(j.accessToken).to.be.undefined);",
            "pm.test('no user', () => pm.expect(j.user).to.be.undefined);"
          ]}}],
          "request": {
            "method": "POST",
