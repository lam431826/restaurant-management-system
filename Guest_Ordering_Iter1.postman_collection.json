					]
				}
			},
			"response": []
		},
		{
			"name": "2. Gửi yêu cầu đặt món mới",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"pm.sendRequest(\"http://localhost:8081/api/menu/public\", function (err, res) {",
							"    if (err) {",
							"        console.log(err);",
							"    } else {",
							"        let menu = res.json();",
							"        let beefId = \"\";",
							"        let cocaId = \"\";",
							"        menu.forEach(cat => {",
							"            cat.items.forEach(item => {",
							"                if (item.name === \"Bò Bít Tết Úc\") beefId = item.id;",
							"                if (item.name === \"Coca Cola\") cocaId = item.id;",
							"            });",
							"        });",
							"        pm.collectionVariables.set(\"beefId\", beefId);",
							"        pm.collectionVariables.set(\"cocaId\", cocaId);",
							"        console.log(\"Saved beefId: \" + beefId);",
							"        console.log(\"Saved cocaId: \" + cocaId);",
							"    }",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"let response = pm.response.json();",
							"if (response && response.orderId) {",
							"    pm.collectionVariables.set(\"orderId\", response.orderId);",
							"    console.log(\"Saved orderId: \" + response.orderId);",
							"}"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"tableId\": \"{{tableId}}\",\r\n  \"tableToken\": \"token-ban-01\",\r\n  \"items\": [\r\n    {\r\n      \"menuItemId\": \"{{beefId}}\",\r\n      \"quantity\": 2,\r\n      \"note\": \"Ít cay, không hành\"\r\n    }\r\n  ],\r\n  \"note\": \"Khách bàn 01 gọi món\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost:8081/api/guest/orders",
