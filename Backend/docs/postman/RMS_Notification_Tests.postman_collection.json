{
  "info": {
    "name": "RMS – Notification Module Tests (NM-01 → NM-04)",
    "_postman_id": "rms-notification-v2",
    "description": "Kiểm thử toàn diện module Notification (NM-01 đến NM-04).\n\nYêu cầu tiên quyết:\n- Backend đã RESTART sau khi code được cập nhật\n- Admin account ACTIVE (đã chạy Auth collection ít nhất một lần)\n- Gmail SMTP cấu hình đúng trong Backend/.env\n\n⚙️ BƯỚC THỦ CÔNG (1 lần trong collection):\n  Sau bước [1.5] → kiểm tra hộp thư tunghieubach@gmail.com\n  Lấy mã OTP 6 chữ số → đặt vào biến Collection 'otp' → tiếp tục chạy\n\nThứ tự chạy: Collection Runner → tuần tự từ trên xuống.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl",            "value": "http://localhost:8387", "type": "string"},
    {"key": "testEmail",          "value": "tunghieubach@gmail.com", "type": "string"},
    {"key": "adminToken",         "value": "", "type": "string"},
    {"key": "cashierToken",       "value": "", "type": "string"},
    {"key": "cashierUsername",    "value": "", "type": "string"},
    {"key": "cashierPassword",    "value": "", "type": "string"},
    {"key": "cashierVerifyToken", "value": "", "type": "string"},
    {"key": "reservationId",      "value": "", "type": "string"},
    {"key": "staffReservationId", "value": "", "type": "string"},
    {"key": "futureDateTime",     "value": "", "type": "string"},
    {"key": "todayStr",           "value": "", "type": "string"},
    {"key": "otp",                "value": "", "type": "string"}
  ],
  "item": [

    {
      "name": "1. Setup",
      "item": [

        {
          "name": "[1.1 ✅] Admin Login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const future = new Date(Date.now() + 2 * 60 * 60 * 1000);",
                  "const pad = n => String(n).padStart(2, '0');",
                  "pm.collectionVariables.set('futureDateTime',",
                  "  `${future.getFullYear()}-${pad(future.getMonth()+1)}-${pad(future.getDate())}T${pad(future.getHours())}:${pad(future.getMinutes())}:00`",
                  ");",
                  "const today = new Date();",
                  "pm.collectionVariables.set('todayStr',",
                  "  `${today.getFullYear()}-${pad(today.getMonth()+1)}-${pad(today.getDate())}`",
                  ");",
                  "const rid = Date.now();",
                  "pm.collectionVariables.set('cashierUsername', 'cashier_nm_' + rid);",
                  "['adminToken','cashierToken','cashierPassword','cashierVerifyToken',",
                  " 'reservationId','staffReservationId','otp']",
                  "  .forEach(k => pm.collectionVariables.set(k, ''));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[1.1] Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('[1.1] Có accessToken', () => pm.expect(j.accessToken).to.be.a('string').and.not.empty);",
                  "pm.test('[1.1] Admin không cần OTP', () => pm.expect(j.requiresVerification).to.be.oneOf([null,undefined,false]));",
                  "pm.collectionVariables.set('adminToken', j.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"username\":\"admin\",\"password\":\"Admin@123456\"}"},
            "url": {"raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"]}
          }
        },

        {
          "name": "[1.2 ✅] Tạo cashier test user (email tunghieubach@gmail.com)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[1.2] Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('[1.2] Có tempPassword', () => pm.expect(j.data.tempPassword).to.be.a('string').and.not.empty);",
                  "pm.test('[1.2] Status UN_ACTIVE', () => pm.expect(j.data.user.status).to.eql('UN_ACTIVE'));",
                  "pm.test('[1.2] Role CASHIER', () => pm.expect(j.data.user.role).to.eql('CASHIER'));",
                  "pm.collectionVariables.set('cashierPassword', j.data.tempPassword);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type",  "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{cashierUsername}}\",\n  \"fullName\": \"NM Test Cashier\",\n  \"email\": \"{{testEmail}}\",\n  \"phone\": \"0900000001\",\n  \"role\": \"CASHIER\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api","users"]}
          }
        },

        {
          "name": "[1.3 ✅] Cashier Login lần đầu → nhận verifyToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[1.3] Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('[1.3] requiresVerification = true', () => pm.expect(j.requiresVerification).to.be.true);",
                  "pm.test('[1.3] Có verifyToken', () => pm.expect(j.verifyToken).to.be.a('string').and.not.empty);",
                  "pm.collectionVariables.set('cashierVerifyToken', j.verifyToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"{{cashierUsername}}\",\"password\":\"{{cashierPassword}}\"}"
            },
            "url": {"raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"]}
          }
        },

        {
          "name": "[1.4 ✅] Gửi OTP kích hoạt → tunghieubach@gmail.com",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[1.4] Status 200 — OTP đã gửi đến tunghieubach@gmail.com', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('[1.4] Có maskedEmail', () => pm.expect(j.data.maskedEmail).to.be.a('string').and.include('*'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "X-Verify-Token", "value": "{{cashierVerifyToken}}"}],
            "url": {"raw": "{{baseUrl}}/api/auth/verify/info", "host": ["{{baseUrl}}"], "path": ["api","auth","verify","info"]}
          }
        },

        {
          "name": "[1.5 ⚙️ THỦ CÔNG] Kiểm tra tunghieubach@gmail.com → đặt biến otp",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ─────────────────────────────────────────────────────────────",
                  "// BƯỚC THỦ CÔNG:",
                  "// 1. Mở hộp thư tunghieubach@gmail.com",
                  "// 2. Tìm email 'Mã xác thực tài khoản RMS'",
                  "// 3. Sao chép mã OTP 6 chữ số",
                  "// 4. Postman → Variables → đặt 'otp' = <mã vừa sao chép>",
                  "// 5. Tiếp tục chạy từ bước [1.6]",
                  "// ─────────────────────────────────────────────────────────────"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const otp = pm.collectionVariables.get('otp');",
                  "pm.test('[1.5] Biến otp đã được đặt thủ công (6 chữ số)',",
                  "  () => pm.expect(otp, 'Mở tunghieubach@gmail.com → copy OTP → đặt biến otp').to.match(/^\\d{6}$/));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify/info",
              "host": ["{{baseUrl}}"], "path": ["api","auth","verify","info"],
              "description": "Placeholder — quan trọng là test script kiểm tra biến otp đã được đặt chưa."
            }
          }
        },

        {
          "name": "[1.6 ✅] Verify OTP → kích hoạt cashier, nhận cashierToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[1.6] Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('[1.6] Có accessToken', () => pm.expect(j.accessToken).to.be.a('string').and.not.empty);",
                  "pm.test('[1.6] Role CASHIER', () => pm.expect(j.user.role).to.eql('CASHIER'));",
                  "pm.collectionVariables.set('cashierToken', j.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type",   "value": "application/json"},
              {"key": "X-Verify-Token", "value": "{{cashierVerifyToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"otp\":\"{{otp}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/auth/verify/otp", "host": ["{{baseUrl}}"], "path": ["api","auth","verify","otp"]}
          }
        },

        {
          "name": "[1.7 ✅] Tạo online reservation CÓ email → reservationId",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[1.7] Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('[1.7] Có data.id', () => pm.expect(j.data.id).to.be.a('string').and.not.empty);",
                  "pm.test('[1.7] Status CONFIRMED', () => pm.expect(j.data.status).to.eql('CONFIRMED'));",
                  "pm.collectionVariables.set('reservationId', j.data.id);",
                  "// Email CONFIRMATION đã được fire-and-forget async — kiểm tra inbox sau"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guestName\": \"Nguyễn Văn Test\",\n  \"phone\": \"0901234567\",\n  \"email\": \"{{testEmail}}\",\n  \"partySize\": 3,\n  \"datetime\": \"{{futureDateTime}}\",\n  \"note\": \"Test NM-01 notification\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/online/reservations", "host": ["{{baseUrl}}"], "path": ["api","online","reservations"]}
          }
        },

        {
          "name": "[1.8 ✅] Tạo staff reservation KHÔNG có email → staffReservationId",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[1.8] Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('[1.8] Có data.id', () => pm.expect(j.data.id).to.be.a('string').and.not.empty);",
                  "pm.collectionVariables.set('staffReservationId', j.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guestName\": \"Khách Không Email\",\n  \"phone\": \"0912345678\",\n  \"partySize\": 2,\n  \"datetime\": \"{{futureDateTime}}\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/reservations/online/new", "host": ["{{baseUrl}}"], "path": ["api","reservations","online","new"]}
          }
        }

      ]
    },

    {
      "name": "2. NM-01 – Gửi thông báo đặt bàn",
      "item": [

        {
          "name": "[2.1 ✅] ADMIN gửi CONFIRMATION → 204 (email async đến tunghieubach@gmail.com)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[2.1] Status 204', () => pm.response.to.have.status(204));",
                  "pm.test('[2.1] Body trống', () => pm.expect(pm.response.text()).to.be.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type",  "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
