            "url": {"raw": "{{baseUrl}}/api/notifications/reservation", "host": ["{{baseUrl}}"], "path": ["api","notifications","reservation"]}
          }
        },

        {
          "name": "[2.6 ❌] Thiếu type → 400 (fieldErrors.type)",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": [
                "pm.test('[2.6] Status 400', () => pm.response.to.have.status(400));",
                "pm.test('[2.6] fieldErrors.type tồn tại', () => pm.expect(pm.response.json().fieldErrors).to.have.property('type'));"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type",  "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"reservationId\": \"{{reservationId}}\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/notifications/reservation", "host": ["{{baseUrl}}"], "path": ["api","notifications","reservation"]}
          }
        },

