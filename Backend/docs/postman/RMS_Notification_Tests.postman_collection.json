              "listen": "test",
              "script": {"type": "text/javascript", "exec": [
                "pm.test('[2.8] Status 400', () => pm.response.to.have.status(400));",
                "pm.test('[2.8] error là BAD_REQUEST', () => pm.expect(pm.response.json().error).to.eql('BAD_REQUEST'));"
              ]}
