          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript",
                "exec": ["pm.test('[2.4] Status 204 — skip khi không có guestEmail', () => pm.response.to.have.status(204));"]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type",  "value": "application/json"},
