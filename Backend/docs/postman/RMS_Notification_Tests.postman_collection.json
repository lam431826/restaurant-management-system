          "name": "[2.7 ❌] Thiếu reservationId → 400 (fieldErrors.reservationId)",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": [
                "pm.test('[2.7] Status 400', () => pm.response.to.have.status(400));",
                "pm.test('[2.7] fieldErrors.reservationId tồn tại', () => pm.expect(pm.response.json().fieldErrors).to.have.property('reservationId'));"
              ]}
