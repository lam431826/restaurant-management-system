          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type",  "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"reservationId\": \"{{reservationId}}\",\n  \"type\": \"REMINDER\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/notifications/reservation", "host": ["{{baseUrl}}"], "path": ["api","notifications","reservation"]}
          }
        },

        {
          "name": "[2.3 ✅] ADMIN gửi CANCELLATION → 204",
          "event": [
