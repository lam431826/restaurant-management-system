          }
        },

        {
          "name": "[2.5 ❌] Reservation không tồn tại → 404",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": [
                "pm.test('[2.5] Status 404', () => pm.response.to.have.status(404));",
